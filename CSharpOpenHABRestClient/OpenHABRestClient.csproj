<Project Sdk="Microsoft.NET.Sdk">

  <PropertyGroup>
    <!-- netstandard2.1 läuft auf .NET 5+, .NET 6/7/8, Unity 2021+, Xamarin -->
    <TargetFrameworks>netstandard2.1;net8.0</TargetFrameworks>
    <Nullable>enable</Nullable>
    <LangVersion>11</LangVersion>
    <ImplicitUsings>enable</ImplicitUsings>

    <!-- NuGet-Paketmetadaten -->
    <PackageId>CSharpOpenHABRestClient</PackageId>
    <Version>1.0.0</Version>
    <Authors>Michael Christian Dörflinger</Authors>
    <Company>michdo93</Company>
    <Description>C# client for the openHAB REST API. Mirrors python-openhab-rest-client. Zero external dependencies.</Description>
    <PackageTags>openhab;smarthome;iot;rest;api;home-automation</PackageTags>
    <PackageProjectUrl>https://github.com/Michdo93/csharp-openhab-rest-client</PackageProjectUrl>
    <RepositoryUrl>https://github.com/Michdo93/csharp-openhab-rest-client</RepositoryUrl>
    <RepositoryType>git</RepositoryType>
    <PackageLicenseExpression>MIT</PackageLicenseExpression>
    <PackageReadmeFile>README.md</PackageReadmeFile>
    <Copyright>Copyright (c) 2026 Michael Christian Dörflinger</Copyright>

    <!-- XML-Dokumentation für IntelliSense -->
    <GenerateDocumentationFile>true</GenerateDocumentationFile>
    <NoWarn>$(NoWarn);1591</NoWarn>

    <!-- NuGet-Symbol-Paket für Debuggen -->
    <IncludeSymbols>true</IncludeSymbols>
    <SymbolPackageFormat>snupkg</SymbolPackageFormat>
  </PropertyGroup>

  <ItemGroup>
    <!-- Keine externen Abhängigkeiten! -->
  </ItemGroup>

  <ItemGroup>
    <None Include="..\README.md" Pack="true" PackagePath="\" />
  </ItemGroup>

</Project>
